{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ffmpeg-gui",
  "version": "0.1.0",
  "identifier": "com.ffmpeggui.app",
  "build": {
    "beforeDevCommand": "pnpm.cmd dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FFmpeg GUI",
        "width": 1120,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
